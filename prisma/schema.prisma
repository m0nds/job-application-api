generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id
  company     String
  role        String
  status      String
  appliedDate String
  notes       String?
  createdAt   DateTime
  updatedAt   DateTime
  jobUrl      String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                    String    @id
  email                 String    @unique
  name                  String
  password              String
  isVerified            Boolean   @default(false)
  verificationToken     String?
  verificationExpiry    DateTime?
  resetPasswordToken    String?
  resetPasswordExpiry   DateTime?
  createdAt             DateTime
  updatedAt             DateTime
  jobs                  Job[]
}